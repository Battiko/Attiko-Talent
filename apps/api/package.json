{
  "name": "@attiko/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts"
  },
  "scripts": {
