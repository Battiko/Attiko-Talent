    "express": "^4.19.0",
    "ioredis": "^5.3.2",
    "neverthrow": "^8.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "superjson": "^2.2.0",
    "zod": "^3.23.0",
    "@paralleldrive/cuid2": "^2.2.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
